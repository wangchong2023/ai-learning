# ==========================================
# AI-Learning 环境配置模板
# 使用方法：将此文件复制为 `.env`，并填入您的真实密钥
# ==========================================

# 1. 核心模型配置 (必填)
DEEPSEEK_API_KEY="sk-your-deepseek-api-key-here"

# 2. LangSmith 可观测性配置 (选填)
# 启用后，可在 https://smith.langchain.com 追踪所有的 Agent 推理轨迹
LANGSMITH_TRACING="false"
LANGSMITH_API_KEY="ls__your-langsmith-api-key-here"
LANGSMITH_PROJECT="AI-Learning-Lab"

# 3. 系统日志 (选填)
# 可选值: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL="INFO"
